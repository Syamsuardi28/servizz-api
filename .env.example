# ============================================================
# SERVIZZ API - Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=servizz_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRES_IN=7d

# Payment Gateway (Midtrans / Snap)
PAYMENT_CALLBACK_SECRET=your_payment_callback_secret_here
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_BASE_URL=https://app.sandbox.midtrans.com/snap/v1/transactions
